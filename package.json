{
  "name": "eowiz",
  "version": "1.0.0",
  "private": true,
  "description": "eowiz",
  "author": "eowiz",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "typecheck": "tsc --noEmit",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "format:prettier": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,md}\" \"gatsby-{config,node}.ts\"",
    "format:eslint": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\" \"gatsby-{config,node}.ts\"",
    "format": "npm run format:eslint && npm run format:prettier",
    "prepare": "husky install"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "npm run format",
    "gatsby-{node,config}.ts": "npm run format"
  },
  "dependencies": {
    "@fontsource/bungee-outline": "^4.5.6",
    "@fontsource/bungee-shade": "^4.5.8",
    "@fontsource/m-plus-rounded-1c": "^4.5.8",
    "@fontsource/noto-sans-jp": "^4.5.10",
    "@fontsource/raleway": "^4.5.9",
    "@fontsource/sawarabi-mincho": "^4.5.8",
    "date-fns": "^2.29.1",
    "gatsby": "^4.18.0",
    "gatsby-plugin-canonical-urls": "^4.20.0",
    "gatsby-plugin-google-analytics": "^4.18.0",
    "gatsby-plugin-image": "^2.18.0",
    "gatsby-plugin-manifest": "^4.18.0",
    "gatsby-plugin-sharp": "^4.18.0",
    "gatsby-plugin-sitemap": "^5.18.0",
    "gatsby-remark-katex": "^6.20.0",
    "gatsby-remark-prismjs": "^6.20.0",
    "gatsby-remark-prismjs-title": "^1.0.0",
    "gatsby-source-filesystem": "^4.18.0",
    "gatsby-transformer-remark": "^5.20.0",
    "gatsby-transformer-sharp": "^4.18.0",
    "katex": "^0.13.24",
    "prismjs": "^1.28.0",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-icons": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.18.9",
    "@babel/runtime": "^7.18.9",
    "@storybook/addon-actions": "^6.5.9",
    "@storybook/addon-essentials": "^6.5.9",
    "@storybook/addon-interactions": "^6.5.9",
    "@storybook/addon-links": "^6.5.9",
    "@storybook/builder-webpack5": "^6.5.9",
    "@storybook/manager-webpack5": "^6.5.9",
    "@storybook/react": "^6.5.9",
    "@storybook/testing-library": "^0.0.13",
    "@types/node": "^17.0.45",
    "@types/react": "^18.0.14",
    "@types/react-dom": "^18.0.5",
    "@typescript-eslint/eslint-plugin": "^5.32.0",
    "@typescript-eslint/parser": "^5.32.0",
    "autoprefixer": "^10.4.8",
    "babel-loader": "^8.2.5",
    "eslint": "^8.21.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.2.4",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-react": "^7.30.1",
    "gatsby-plugin-postcss": "^5.20.0",
    "gatsby-plugin-root-import": "^2.0.8",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "postcss": "^8.4.14",
    "prettier": "^2.7.1",
    "storybook-addon-gatsby": "^0.0.5",
    "tailwindcss": "^3.1.8",
    "typescript": "^4.7.4"
  }
}
